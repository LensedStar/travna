# Environment variables for Dom na Travni gori — copy to `.env` and fill real values at launch.
# `.env` is gitignored (never commit real IDs/secrets). This `.env.example` is the documented template.

# Google Analytics 4 measurement ID (TASK-029). [MOCK] placeholder until Webline sets the real value.
# Must use the PUBLIC_ prefix so Astro exposes it to the consent-gated client script.
# GA4 loads ONLY after the visitor accepts the cookie-consent banner (src/components/layout/CookieConsent.astro).
PUBLIC_GA_MEASUREMENT_ID=GA_MEASUREMENT_ID
