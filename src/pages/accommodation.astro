---
// accommodation.astro — Apartments page.
// Sections top → bottom: hero/intro (photo + location copy), bonuses (incl. Booking 8.8 score +
// pet-friendly), units (houses & rooms shown separately, with photos), breakfast & homemade
// kitchen, guest testimonials, and the shared book-direct prefooter strip.
// Unit selection & pricing stay on /rezervacija (Bentral). All visible strings come from the i18n
// dictionary; section styles live in their own src/styles/blocks/_*.scss files. Copy/photos are MOCK.
import BaseLayout from '../layouts/BaseLayout.astro';
import AccommodationHero from '../components/sections/AccommodationHero.astro';
import AccommodationUnits from '../components/sections/AccommodationUnits.astro';
import AccommodationKitchen from '../components/sections/AccommodationKitchen.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import FindUs from '../components/sections/FindUs.astro';
import BookDirect from '../components/sections/BookDirect.astro';
import { useTranslations, defaultLocale } from '../i18n';

const t = useTranslations(defaultLocale);
const pageTitle = `${t('accommodation.title')} — ${t('site.name')}`;
---

<BaseLayout title={pageTitle} description={t('accommodation.description')}>
  <AccommodationHero />
  <AccommodationUnits />
  <AccommodationKitchen />
  <Testimonials />
  <FindUs showSprig={false} />
  <BookDirect />
</BaseLayout>
