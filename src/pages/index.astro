---
// [MOCK] placeholder home page — now rendered through BaseLayout (TASK-007).
// TODO: implement the real Home (TASK-016) with Header nav, hero parallax and section components.
// Visible strings come from the i18n dictionary — no hardcoded copy.
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations, defaultLocale } from '../i18n';

const t = useTranslations(defaultLocale);
---

<BaseLayout title={t('site.name')} description={t('site.tagline')}>
  <h1>{t('site.name')}</h1>
  <p>{t('site.tagline')}</p>
</BaseLayout>
