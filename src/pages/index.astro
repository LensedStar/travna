---
// Home page — rendered through BaseLayout (TASK-007). Sections top → bottom: hero (TASK-014),
// value props (TASK-015), accommodation preview + activities preview + book-direct strip (TASK-016).
// Visible strings come from the i18n dictionary — no hardcoded copy.
import BaseLayout from '../layouts/BaseLayout.astro';
import ParallaxHero from '../islands/ParallaxHero.jsx';
import RegionExplore from '../components/sections/RegionExplore.astro';
import HeritageTimeline from '../components/sections/HeritageTimeline.astro';
import ApartmentShowcase from '../components/sections/ApartmentShowcase.astro';
import HomeGallery from '../components/sections/HomeGallery.astro';
import FindUs from '../components/sections/FindUs.astro';
import BookDirect from '../components/sections/BookDirect.astro';
import { useTranslations, defaultLocale } from '../i18n';

const t = useTranslations(defaultLocale);
---

<BaseLayout title={t('site.name')} description={t('site.tagline')}>
  <ParallaxHero
    client:load
    title={t('home.hero.title')}
    subtitle={t('home.hero.subtitle')}
    eyebrow={t('home.hero.eyebrow')}
    ctaPrimaryLabel={t('cta.checkAvailability')}
    ctaSecondaryLabel={t('cta.exploreArea')}
    ratingsLabel={t('home.hero.ratingsLabel')}
    bookingLabel={t('home.hero.bookingLabel')}
    airbnbLabel={t('home.hero.airbnbLabel')}
  />
  <RegionExplore />
  <HeritageTimeline />
  <ApartmentShowcase />
  <HomeGallery />
  <FindUs />
  <BookDirect />
</BaseLayout>

