---
// Footer.astro — global site footer rendered on EVERY page via BaseLayout (TASK-013).
// Brand logo + legal entity, a footer nav row with social icons, then a centered
// rights line and agency credit. All visible text comes from the i18n dictionary —
// no hardcoded strings in the component.
import { useTranslations, defaultLocale } from '../../i18n';
import Icon from '../ui/Icon.astro';

const t = useTranslations(defaultLocale);

// config values (non-visible hrefs — not UI copy).
// TODO(Webline): replace with the real social profiles and privacy-policy route.
const instagramUrl = 'https://instagram.com/'; // TODO
const facebookUrl = 'https://facebook.com/'; // TODO

const footerNav = [
  { href: '/accommodation', label: t('footer.nav.accommodation') },
  { href: '/activities', label: t('footer.nav.activities') },
  { href: '/contact', label: t('footer.nav.contact') },
  { href: '/privacy', label: t('footer.nav.privacy') }, // TODO(Webline): privacy-policy page
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__main">
      <div class="site-footer__left">
        <a class="site-footer__brand" href="/" aria-label={t('site.name')}>
          <img
            class="site-footer__logo"
            src="/images/logo.png"
            alt={t('site.name')}
            width="512"
            height="512"
            decoding="async"
            loading="lazy"
          />
        </a>

        <div class="site-footer__nav-row">
          <nav class="site-footer__nav" aria-label={t('a11y.footerNav')}>
            <ul class="site-footer__nav-list">
              {
                footerNav.map((link) => (
                  <li class="site-footer__nav-item">
                    <a class="site-footer__nav-link" href={link.href}>
                      {link.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </nav>

          <ul class="site-footer__social" aria-label={t('footer.social.title')}>
            <li>
              <a
                class="site-footer__social-link"
                href={instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={t('footer.social.instagram')}
              >
                <Icon name="instagram" class="site-footer__social-icon" />
              </a>
            </li>
            <li>
              <a
                class="site-footer__social-link"
                href={facebookUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={t('footer.social.facebook')}
              >
                <Icon name="facebook" class="site-footer__social-icon" />
              </a>
            </li>
          </ul>
        </div>
      </div>

      <address class="site-footer__legal">
        <span class="site-footer__legal-line">{t('footer.legal.entity')}</span>
        <span class="site-footer__legal-line">{t('footer.legal.address')}</span>
        <span class="site-footer__legal-line">{t('footer.legal.country')}</span>
        <span class="site-footer__legal-line">{t('footer.legal.taxId')}</span>
      </address>
    </div>

    <hr class="site-footer__divider" />

    <p class="site-footer__rights">{year} {t('footer.rights')}</p>
    <p class="site-footer__credit">
      {t('footer.credit.text')} <strong>{t('footer.credit.company')}</strong>
    </p>
  </div>
</footer>
