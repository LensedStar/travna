---
// Icon.astro — UI primitive (pure .astro, no client JS).
// Renders line-style SVG icons (consistent stroke weight) by `name`, matching the
// Lucide/Phosphor line aesthetic from CLAUDE.md §7. [MOCK] placeholder set — TODO: confirm the
// final icon set with the client. Color is inherited (stroke="currentColor") so callers theme it
// via a token-driven `color` in their SCSS block; sizing is controlled by the caller's class.
interface Props {
  name: string;
  class?: string;
  [key: string]: unknown;
}
const { name, class: className, ...rest } = Astro.props;
const classes = ['icon', className].filter(Boolean).join(' ');

// Line-style path data per icon name. The 24×24 viewBox + stroke-width are intrinsic SVG geometry
// (not styling tokens). Keys match the `icon` field used by the valueProps collection.
const paths: Record<string, string> = {
  trees: '<path d="M12 3 8 9h8z"/><path d="M9.5 9 6 15h12l-3.5-6"/><path d="M12 15v6"/>',
  feather: '<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><path d="M16 8 2 22"/><path d="M17.5 15H9"/>',
  map: '<polygon points="3 6 9 3 15 6 21 3 21 18 15 21 9 18 3 21"/><path d="M9 3v15"/><path d="M15 6v15"/>',
  flame: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
};
const path = paths[name] ?? '';
---
<svg
  class={classes}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  focusable="false"
  set:html={path}
  {...rest}
/>
