---
// Button.astro — UI primitive (pure .astro, no client JS).
// Renders an <a> when `href` is given, otherwise a <button>. Styling lives entirely in
// src/styles/blocks/_buttons.scss (semantic .btn / .btn--* classes) — no inline styles here.
// Visible label is passed in via <slot> by the caller (text comes from the i18n dictionary).
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}
const { href, variant = 'primary', type = 'button', class: className, ...rest } = Astro.props;
const classes = ['btn', `btn--${variant}`, className].filter(Boolean).join(' ');
---
{
  href ? (
    <a href={href} class={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}
