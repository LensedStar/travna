---
// HomeGallery.astro - Scroll-driven home gallery section with sticky stage and zoomable images.
// Reuses the structured `gallery` collection and augments it with extra mock images so the home
// gallery feels like a longer photo story rather than a four-card teaser.
import { getCollection } from 'astro:content';
import { getImage } from 'astro:assets';
import HomeGalleryScroller from '../../islands/HomeGalleryScroller.jsx';
import { useTranslations, defaultLocale } from '../../i18n';

const t = useTranslations(defaultLocale);
const entries = (await getCollection('gallery')).sort((a, b) => a.data.order - b.data.order);
const sizes = '(max-width: 48rem) 92vw, (max-width: 75rem) 50vw, 33vw';
const labels = [
  t('home.gallery.card.1'),
  t('home.gallery.card.2'),
  t('home.gallery.card.3'),
  t('home.gallery.card.4'),
];
const optimizedImages = await Promise.all(
  entries.map(async ({ data }, index) => {
    const optimized = await getImage({
      src: data.src,
      widths: index === 0 ? [720, 1100, 1500] : [480, 760, 1100],
      sizes,
      format: 'webp',
    });

    return {
      src: optimized.src,
      srcset: optimized.srcSet.attribute,
      sizes,
      width: data.src.width,
      height: data.src.height,
      alt: data.alt,
      label: labels[index],
    };
  })
);

const extraImages = [
  {
    src: '/images/ttravna now.webp',
    srcset: '',
    sizes: '100vw',
    width: 1600,
    height: 1067,
    alt: 'Mock exterior view of the house surrounded by greenery.',
    label: t('home.gallery.card.5'),
  },
  {
    src: '/images/accommodation-preview.webp',
    srcset: '',
    sizes: '100vw',
    width: 1600,
    height: 1200,
    alt: 'Mock bedroom and sitting area detail.',
    label: t('home.gallery.card.6'),
  },
];

const images = [...optimizedImages.slice(0, 4), ...extraImages];
---

<HomeGalleryScroller
  client:visible
  eyebrow={t('home.gallery.eyebrow')}
  title={t('home.gallery.title')}
  intro={t('home.gallery.intro')}
  openLabel={t('home.gallery.open')}
  closeLabel={t('home.gallery.close')}
  outroTitle={t('home.gallery.outro.title')}
  outroText={t('home.gallery.outro.text')}
  ctaLabel={t('home.gallery.outro.cta')}
  images={images}
/>


