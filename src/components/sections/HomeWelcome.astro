---
// HomeWelcome.astro — Home "welcome to the house" block (replaces the old Dolenjska region block).
// First section after the hero: the circular house photo rises up into the hero's wave so the
// landscape photography and the house photo read as one composition, beside editorial copy in the
// same visual language as the accommodation/activities page heroes (offset ring + scattered leaves
// + round badge + divider + pills). Pure .astro, zero client JS. Visible strings come from the
// i18n dictionary; styling lives in src/styles/blocks/_home-welcome.scss. Copy is MOCK placeholder
// (see en.ts // TODO).
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, defaultLocale } from '../../i18n';

const t = useTranslations(defaultLocale);

// House-highlight pills — line-icon + i18n key. Reorder/extend here without touching the layout.
const pills = [
  { icon: 'bed', key: 'home.welcome.pill.apartments' },
  { icon: 'flame', key: 'home.welcome.pill.kitchen' },
  { icon: 'trees', key: 'home.welcome.pill.forest' },
  { icon: 'paw-print', key: 'home.welcome.pill.pets' },
] as const;
---
<section class="home-welcome reveal">
  <div class="home-welcome__inner">
    <div class="home-welcome__media-col">
      <div class="home-welcome__ring" aria-hidden="true"></div>

      <div class="home-welcome__media">
        <!-- MOCK placeholder photo — TODO(Webline): swap for the real house photo. -->
        <img
          class="home-welcome__photo"
          src="/images/ttravna now.webp"
          alt={t('home.welcome.imageAlt')}
          width="608"
          height="352"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Scattered botanical leaves — purely decorative atmosphere. -->
      <Icon name="leaf" class="home-welcome__leaf home-welcome__leaf--tr" />
      <Icon name="leaf" class="home-welcome__leaf home-welcome__leaf--bl" />
      <Icon name="leaf" class="home-welcome__leaf home-welcome__leaf--bl2" />

      <span class="home-welcome__badge">
        <Icon name="heart" class="home-welcome__badge-icon" />
        <span class="home-welcome__badge-title">{t('home.welcome.badge.title')}</span>
        <span class="home-welcome__badge-sub">{t('home.welcome.badge.sub')}</span>
      </span>
    </div>

    <div class="home-welcome__body">
      <p class="home-welcome__eyebrow">{t('home.welcome.eyebrow')}</p>
      <h2 class="home-welcome__title">{t('home.welcome.title')}</h2>

      <div class="home-welcome__divider" aria-hidden="true">
        <span class="home-welcome__divider-line"></span>
        <Icon name="home" class="home-welcome__divider-icon" />
        <span class="home-welcome__divider-line"></span>
      </div>

      <p class="home-welcome__lead">{t('home.welcome.lead')}</p>
      <p class="home-welcome__text">{t('home.welcome.body')}</p>

      <ul class="home-welcome__pills" role="list">
        {pills.map(({ icon, key }) => (
          <li class="home-welcome__pill">
            <Icon name={icon} class="home-welcome__pill-icon" />
            <span>{t(key)}</span>
          </li>
        ))}
      </ul>

      <div class="home-welcome__cta">
        <Button href="/accommodation" variant="secondary">{t('cta.viewAccommodation')}</Button>
      </div>
    </div>
  </div>
</section>
