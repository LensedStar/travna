---
// RegionExplore.astro — Home "Discover the Dolenjska region" block.
// Static regional locator map (public/images/dolenjska.jpg) + a bullet list of nearby attractions.
// Pure .astro, zero client JS. Visible strings come from the i18n dictionary; styling lives in
// src/styles/blocks/_region-explore.scss. The highlight copy references real Dolenjska attractions
// (visitdolenjska.eu) — no invented distances or property-specific claims.
import Button from '../ui/Button.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, defaultLocale } from '../../i18n';

const t = useTranslations(defaultLocale);

// Bullet list — line-icon + i18n key. Reorder/extend here without touching the layout.
const highlights = [
  { icon: 'waves', key: 'home.region.item.krka' },
  { icon: 'thermometer', key: 'home.region.item.spas' },
  { icon: 'wine', key: 'home.region.item.wine' },
  { icon: 'landmark', key: 'home.region.item.towns' },
  { icon: 'bike', key: 'home.region.item.cycling' },
  { icon: 'mountain', key: 'home.region.item.hiking' },
] as const;
---
<section class="region-explore reveal">
  <div class="region-explore__inner">
    <div class="region-explore__body">
      <SectionHeader title={t('home.region.title')} subtitle={t('home.region.intro')} align="left" />

      <ul class="region-explore__list">
        {highlights.map(({ icon, key }) => (
          <li class="region-explore__item">
            <Icon name={icon} class="region-explore__icon" />
            <span class="region-explore__item-text">{t(key)}</span>
          </li>
        ))}
      </ul>

      <Button href="/activities" variant="secondary">{t('cta.exploreArea')}</Button>
    </div>

    <div class="region-explore__map">
      <img
        class="region-explore__map-img"
        src="/images/dolenjska.png"
        alt={t('home.region.mapAlt')}
        width="1264"
        height="848"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
</section>
