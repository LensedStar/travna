---
// Testimonials.astro — guest reviews block (reusable across pages).
// Centred header + a grid of quote cards, each with a 5-star row, the quote, and the guest's
// name + meta. Pure .astro, zero client JS. Visible strings from the i18n dictionary; styling
// lives in src/styles/blocks/_testimonials.scss. Quotes are MOCK — TODO(Webline): real reviews,
// do NOT invent attributed quotes before launch.
import SectionHeader from '../ui/SectionHeader.astro';
import Icon from '../ui/Icon.astro';
import { useTranslations, defaultLocale } from '../../i18n';

const t = useTranslations(defaultLocale);

const reviews = [
  { quote: t('testimonials.t1.quote'), author: t('testimonials.t1.author'), meta: t('testimonials.t1.meta') },
  { quote: t('testimonials.t2.quote'), author: t('testimonials.t2.author'), meta: t('testimonials.t2.meta') },
  { quote: t('testimonials.t3.quote'), author: t('testimonials.t3.author'), meta: t('testimonials.t3.meta') },
];

const stars = [0, 1, 2, 3, 4];
---
<section class="testimonials reveal">
  <div class="testimonials__inner">
    <SectionHeader
      eyebrow={t('testimonials.eyebrow')}
      title={t('testimonials.title')}
      subtitle={t('testimonials.intro')}
      align="center"
    />

    <ul class="testimonials__grid" role="list">
      {reviews.map((review) => (
        <li class="testimonials__card">
          <Icon name="quote" class="testimonials__quote-mark" />
          <div class="testimonials__stars" role="img" aria-label={t('testimonials.ratingLabel')}>
            {stars.map(() => <Icon name="star" class="testimonials__star" />)}
          </div>
          <blockquote class="testimonials__quote">{review.quote}</blockquote>
          <footer class="testimonials__author">
            <span class="testimonials__author-name">{review.author}</span>
            <span class="testimonials__author-meta">{review.meta}</span>
          </footer>
        </li>
      ))}
    </ul>
  </div>
</section>
