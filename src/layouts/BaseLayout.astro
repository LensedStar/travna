---
// BaseLayout.astro — the single layout used by every page (TASK-007).
// Builds <head> (meta, canonical, Open Graph / Twitter), sets <html lang="en">, loads the global
// SCSS (which @font-faces the self-hosted fonts), renders the skip link + global Header/Footer,
// and exposes a content slot. Per-page SEO (title/description/og/JSON-LD) flows in via props — no
// hardcoded meta in pages. The `noindex` prop powers the hidden /lp landing (TASK-025).
import { useTranslations, defaultLocale } from '../i18n';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import CookieConsent from '../components/layout/CookieConsent.astro';
import '../styles/main.scss';

interface Props {
  title: string;
  description: string;
  // Self-referencing canonical. Defaults to the current path resolved against SITE_URL (Astro.site).
  canonicalURL?: string | URL;
  // OG share image. TODO: replace public/images/og-default.png before launch.
  ogImage?: string;
  // Adds <meta name="robots" content="noindex, nofollow"> (used by /lp).
  noindex?: boolean;
  // Omits the global Header/Footer chrome for distraction-free pages (used by /lp — TASK-025).
  bare?: boolean;
}

const {
  title,
  description,
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  ogImage = '/images/og-default.png', // TODO: add the real OG image
  noindex = false,
  bare = false,
} = Astro.props;

const t = useTranslations(defaultLocale);

// Absolute URLs for OG/canonical based on the SITE_URL placeholder (Astro.site, set in astro.config.mjs).
const canonical = new URL(canonicalURL, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
const siteRoot = new URL('/', Astro.site).toString();

// JSON-LD LodgingBusiness/LocalBusiness structured data (TASK-027). Business-level — same on every
// indexable page. All fields are placeholders sourced from the i18n dictionary where one
// already exists (brand name, tagline, phone/email/address) — TODO: replace with the client's
// real lodging data before launch. Emitted only on indexable pages (suppressed for /lp via `noindex`).
const lodgingSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: t('site.name'),
  description: t('site.tagline'), // TODO
  url: siteRoot,
  image: ogImageURL, // TODO: real OG/property image
  telephone: t('footer.contact.phone'), // TODO
  email: t('footer.contact.email'), // TODO
  address: {
    '@type': 'PostalAddress',
    streetAddress: t('footer.legal.address'), // TODO
    addressCountry: 'SI', // Slovenia — region stated in the PRD, not invented
  },
  // TODO: add geo (lat/lng), priceRange, starRating and amenityFeature once the client
  // provides real data — placeholders only here, no invented facts.
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- favicon (TODO: real logo mark). A linked icon prevents the browser's automatic
         /favicon.ico request 404ing into the console (Lighthouse Best Practices). -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {!noindex && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={t('site.name')} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD LodgingBusiness structured data (indexable pages only; /lp is excluded). -->
    {!noindex && <script type="application/ld+json" set:html={JSON.stringify(lodgingSchema)} />}

    <!--
      Scroll-reveal utility (TASK-026). Inline + synchronous so `has-reveal` is set before first paint
      (no flash): the hidden initial state of `.reveal` applies only once this runs. Disabled under
      prefers-reduced-motion / no IntersectionObserver, leaving `.reveal` content fully visible.
      A single IntersectionObserver reveals each `.reveal` once it enters the viewport, then unobserves.
    -->
    <script is:inline>
      (function () {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) return;
        document.documentElement.classList.add('has-reveal');
        function init() {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                io.unobserve(entry.target);
              }
            });
          }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
          document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  </head>
  <body class={bare ? undefined : 'has-fixed-header'}>
    <a class="skip-link" href="#main-content">{t('a11y.skipToContent')}</a>
    {!bare && <Header />}
    {!bare && (
      <!--
        Keep the content offset in sync with the fixed header's real height (it changes with
        viewport / wrapping). Sets the `--header-height` var consumed in blocks/_header.scss; the
        SCSS fallback covers the pre-script paint so there is no jump.
      -->
      <script is:inline>
        (function () {
          var header = document.querySelector('.site-header');
          if (!header) return;
          function sync() {
            document.documentElement.style.setProperty('--header-height', header.offsetHeight + 'px');
          }
          sync();
          if ('ResizeObserver' in window) {
            new ResizeObserver(sync).observe(header);
          } else {
            window.addEventListener('resize', sync);
          }
        })();
      </script>
    )}
    <main id="main-content">
      <slot />
    </main>
    {!bare && <Footer />}
    <!-- GDPR consent gate for GA4 — present on every page (incl. bare /lp). Loads analytics only after consent. -->
    <CookieConsent />
  </body>
</html>
