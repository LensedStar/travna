---
// BaseLayout.astro — the single layout used by every page (TASK-007).
// Builds <head> (meta, canonical, Open Graph / Twitter), sets <html lang="en">, loads the global
// SCSS (which @font-faces the self-hosted fonts), renders the skip link + global Header/Footer,
// and exposes a content slot. Per-page SEO (title/description/og/JSON-LD) flows in via props — no
// hardcoded meta in pages. The `noindex` prop powers the hidden /lp landing (TASK-025).
import { useTranslations, defaultLocale } from '../i18n';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/main.scss';

interface Props {
  title: string;
  description: string;
  // Self-referencing canonical. Defaults to the current path resolved against SITE_URL (Astro.site).
  canonicalURL?: string | URL;
  // [MOCK] OG share image. TODO: replace public/images/og-default.png before launch.
  ogImage?: string;
  // Adds <meta name="robots" content="noindex, nofollow"> (used by /lp).
  noindex?: boolean;
  // Omits the global Header/Footer chrome for distraction-free pages (used by /lp — TASK-025).
  bare?: boolean;
}

const {
  title,
  description,
  canonicalURL = new URL(Astro.url.pathname, Astro.site),
  ogImage = '/images/og-default.png', // [MOCK] TODO: add the real OG image
  noindex = false,
  bare = false,
} = Astro.props;

const t = useTranslations(defaultLocale);

// Absolute URLs for OG/canonical based on the SITE_URL placeholder (Astro.site, set in astro.config.mjs).
const canonical = new URL(canonicalURL, Astro.site).toString();
const ogImageURL = new URL(ogImage, Astro.site).toString();
const siteRoot = new URL('/', Astro.site).toString();

// JSON-LD LodgingBusiness/LocalBusiness structured data (TASK-027). Business-level — same on every
// indexable page. All fields are [MOCK] placeholders sourced from the i18n dictionary where one
// already exists (brand name, tagline, [MOCK] phone/email/address) — TODO: replace with the client's
// real lodging data before launch. Emitted only on indexable pages (suppressed for /lp via `noindex`).
const lodgingSchema = {
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: t('site.name'),
  description: t('site.tagline'), // [MOCK] TODO
  url: siteRoot,
  image: ogImageURL, // [MOCK] TODO: real OG/property image
  telephone: t('footer.contact.phone'), // [MOCK] TODO
  email: t('footer.contact.email'), // [MOCK] TODO
  address: {
    '@type': 'PostalAddress',
    streetAddress: t('footer.legal.address'), // [MOCK] TODO
    addressCountry: 'SI', // Slovenia — region stated in the PRD, not invented
  },
  // [MOCK] TODO: add geo (lat/lng), priceRange, starRating and amenityFeature once the client
  // provides real data — placeholders only here, no invented facts.
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {!noindex && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={t('site.name')} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD LodgingBusiness structured data (indexable pages only; /lp is excluded). -->
    {!noindex && <script type="application/ld+json" set:html={JSON.stringify(lodgingSchema)} />}

    <!--
      Scroll-reveal utility (TASK-026). Inline + synchronous so `has-reveal` is set before first paint
      (no flash): the hidden initial state of `.reveal` applies only once this runs. Disabled under
      prefers-reduced-motion / no IntersectionObserver, leaving `.reveal` content fully visible.
      A single IntersectionObserver reveals each `.reveal` once it enters the viewport, then unobserves.
    -->
    <script is:inline>
      (function () {
        var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduce || !('IntersectionObserver' in window)) return;
        document.documentElement.classList.add('has-reveal');
        function init() {
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-revealed');
                io.unobserve(entry.target);
              }
            });
          }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
          document.querySelectorAll('.reveal').forEach(function (el) { io.observe(el); });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', init);
        } else {
          init();
        }
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t('a11y.skipToContent')}</a>
    {!bare && <Header />}
    <main id="main-content">
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
